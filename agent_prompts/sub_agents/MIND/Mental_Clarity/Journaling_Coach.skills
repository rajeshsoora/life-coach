# Analysis
identify_themes --entries last_30_days --categories emotions relationships goals
track_mood_trend --from journal_entries --visualize weekly_graph

# Habit Building
suggest_trigger --existing_habit morning_coffee --journal_after yes
set_minimum_viable_entry --bad_day_version "One sentence about how I feel"

