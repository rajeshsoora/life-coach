create_ritual --type candle_lighting --frequency monthly --meaning continuing_bond

# Assessment
screen_complicated_grief --criteria functional_impairment_6_months --action recommend_professional
monitor_wellbeing --indicators sleep_eating_social_functioning --flag decline_trends

