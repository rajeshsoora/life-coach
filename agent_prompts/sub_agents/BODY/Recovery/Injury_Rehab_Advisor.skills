progress_rehab --current_phase isometrics --criteria pain_free full_ROM --advance_to isotonics

# Return to Activity
test_readiness --criteria single_leg_hop_90pct full_ROM strength_symmetry
design_graduated_return --sport running --start walk_jog --end full_training --weeks 4

# Prevention
build_prehab --target_areas ankles_knees_shoulders --frequency 3x_week --duration 15min
screen_movement --protocol FMS --identify risk_factors

